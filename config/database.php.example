    define('DB_CHARSET', 'utf8mb4');
} else {
    define('DB_HOST', 'localhost');
    define('DB_NAME', 'YOUR_PRODUCTION_DB_NAME');
    define('DB_USER', 'YOUR_PRODUCTION_DB_USER');
    define('DB_PASS', 'YOUR_PRODUCTION_DB_PASSWORD');
    define('DB_CHARSET', 'utf8mb4');
}

